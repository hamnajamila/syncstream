rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email == request.auth.token.email
        && data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt'])
        && data.keys().size() == 4
        && data.displayName is string && data.displayName.size() <= 100
        && data.createdAt == request.time;
    }

    function isValidBoard(data) {
      return data.ownerId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.category in ['University', 'Home', 'Work', 'Institute', 'Other']
        && data.keys().hasAll(['name', 'category', 'ownerId', 'createdAt'])
        && data.keys().size() == 4
        && data.createdAt == request.time;
    }

    function isValidTask(data) {
      return data.ownerId == request.auth.uid
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.type in ['task', 'meeting', 'quiz']
        && data.status in ['pending', 'completed']
        && data.deadline is timestamp
        // Verify parent board ownership (Master Gate)
        && get(/databases/$(database)/documents/boards/$(data.boardId)).data.ownerId == request.auth.uid;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName'])
        && request.resource.data.displayName is string && request.resource.data.displayName.size() <= 100;
    }

    match /boards/{boardId} {
      allow get: if isOwner(resource.data.ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(boardId) && isValidBoard(request.resource.data);
      allow update: if isOwner(resource.data.ownerId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'category'])
        && request.resource.data.name is string && request.resource.data.name.size() <= 100;
      allow delete: if isOwner(resource.data.ownerId);

      match /tasks/{taskId} {
        // Master Gate: The parent board must belong to the user
        function parentBoardOwnerId() {
           return get(/databases/$(database)/documents/boards/$(boardId)).data.ownerId;
        }

        allow get: if isSignedIn() && parentBoardOwnerId() == request.auth.uid;
        allow list: if isSignedIn() && parentBoardOwnerId() == request.auth.uid && resource.data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && parentBoardOwnerId() == request.auth.uid && isValidId(taskId) && isValidTask(request.resource.data);
        allow update: if isSignedIn() && parentBoardOwnerId() == request.auth.uid
          && (
            // Action: Edit Task
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'deadline', 'type', 'status', 'priority', 'updatedAt'])
            && request.resource.data.updatedAt == request.time
          );
        allow delete: if isSignedIn() && parentBoardOwnerId() == request.auth.uid;
      }
    }
  }
}
